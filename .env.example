# used in: BackEnd/shared/config/env.js, FrontEnd/src/config/env.ts
APPWRITE_API_KEY=

# used in: BackEnd/auth/appwrite/setupdb.js, BackEnd/shared/config/env.js, FrontEnd/src/config/env.ts
APPWRITE_DATABASE_ID=
APPWRITE_USERS_TABLE_ID=users

# used in: BackEnd/shared/config/env.js
APPWRITE_EMAIL_VERIFICATION_URL=

# used in: BackEnd/shared/config/env.js
APPWRITE_ENDPOINT=

# used in: BackEnd/shared/config/env.js, FrontEnd/src/config/env.ts
APPWRITE_PROJECT_ID=

# backend callback base, for example http://localhost
EXPRESS_APP_BASE_URL=
EXPRESS_PORT=5000

# The backend API key must include these Appwrite scopes for auth/register:
# users.read, users.write, rows.read, rows.write, sessions.write
